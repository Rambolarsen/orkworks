{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/doc-check.sh\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "command -v node >/dev/null 2>&1 && node \".claude/hooks/ponytail/hooks/ponytail-activate.js\" || exit 0",
            "timeout": 5,
            "statusMessage": "Loading ponytail mode..."
          }
        ]
      },
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "command -v node >/dev/null 2>&1 && node \".claude/hooks/ponytail/hooks/ponytail-activate.js\" || exit 0",
            "commandWindows": "if (Get-Command node -ErrorAction SilentlyContinue) { node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\ponytail-activate.js\" }",
            "timeout": 5,
            "statusMessage": "Loading ponytail mode..."
          }
        ]
      },
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\".claude/hooks/superpowers/hooks/run-hook.cmd\" session-start",
            "async": false
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v node >/dev/null 2>&1 && node \".claude/hooks/ponytail/hooks/ponytail-mode-tracker.js\" || exit 0",
            "timeout": 5,
            "statusMessage": "Tracking ponytail mode..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v node >/dev/null 2>&1 && node \".claude/hooks/ponytail/hooks/ponytail-mode-tracker.js\" || exit 0",
            "commandWindows": "if (Get-Command node -ErrorAction SilentlyContinue) { node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\ponytail-mode-tracker.js\" }",
            "timeout": 5,
            "statusMessage": "Tracking ponytail mode..."
          }
        ]
      }
    ],
    "sessionStart": [
      {
        "type": "command",
        "bash": "node \".claude/hooks/ponytail/hooks/ponytail-activate.js\"",
        "powershell": "node \".claude/hooks/ponytail/hooks/ponytail-activate.js\"",
        "timeoutSec": 5
      },
      {
        "command": "./hooks/run-hook.cmd session-start"
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "node \".claude/hooks/ponytail/hooks/ponytail-mode-tracker.js\"",
        "powershell": "node \".claude/hooks/ponytail/hooks/ponytail-mode-tracker.js\"",
        "timeoutSec": 5
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  }
}
