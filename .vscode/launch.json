{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch OrkWorks",
      "type": "node-terminal",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "command": "pnpm --dir apps/desktop dev",
