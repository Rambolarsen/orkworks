{
  "name": "orkworks-desktop",
  "productName": "OrkWorks",
  "version": "0.1.0",
  "description": "OrkWorks — Mission Control for AI Agents",
  "main": "dist-electron/main.js",
  "scripts": {
    "postinstall": "node scripts/setup-electron.mjs",
    "dev": "tsc -p tsconfig.node.json && node scripts/dev.mjs",
    "build": "tsc -p tsconfig.node.json && vite build",
    "build:rust": "cargo build --manifest-path ../../crates/orkworksd/Cargo.toml",
    "build:rust:release": "cargo build --release --manifest-path ../../crates/orkworksd/Cargo.toml",
    "package:release": "node scripts/package-release.mjs",
    "dist": "tsc -p tsconfig.node.json && vite build && node scripts/package-release.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "dockview": "^6.6.1",
    "dockview-react": "^6.6.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "allowScripts": {
    "electron": true,
    "esbuild": true,
    "fsevents": true
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.0",
    "electron": "^39.1.0",
    "electron-builder": "^26.1.1",
    "typescript": "^5.9.0",
    "vite": "^7.2.0"
  }
}
